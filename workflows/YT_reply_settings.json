      "id": "1d3f69aa-b562-43d3-a758-ce4a1275d197",
      "name": "Google Gemini Chat Model1",
      "credentials": {
        "googlePalmApi": {
          "id": "pUc8FHkL6VjEgiDX",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.output;\n\n// 統一處理：可能是字串（傳統）或物件（structured output）\nlet rawString = typeof raw === 'string' ? raw : JSON.stringify(raw);\nrawString = rawString.replace(/```json|```/g, '').trim();\n\nconst lines = rawString.split('\\n').filter(line => line.trim());\nconst results = [];\n\nfor (const line of lines) {\n  try {\n    const data = JSON.parse(line.trim());\n    \n    // 驗證必要欄位\n    if (!data.url || !data.id || !data.key || !data.reply) {\n      console.log('缺欄位，跳過:', line);\n      continue;\n    }\n    \n    // 驗證 id 格式（11 字元 + 合法字元）\n    if (!/^[A-Za-z0-9_-]{11}$/.test(String(data.id).trim())) {\n      console.log('id 格式錯誤，跳過:', data.id);\n      continue;\n    }\n    \n    // 強制轉字串 + trim\n    results.push({\n      json: {\n        url: String(data.url).trim(),\n        id: String(data.id).trim(),\n        key: String(data.key).trim(),\n        reply: String(data.reply).trim()\n      }\n    });\n  } catch (e) {\n    console.log('JSON parse 失敗，跳過:', line, e.message);\n  }\n}\n\nif (results.length === 0) {\n  throw new Error('AI 沒回傳任何有效資料');\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
